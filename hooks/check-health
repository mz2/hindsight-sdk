#!/usr/bin/bash
# Runs as root after setup-project. Reports SDK health to Workshop.
set -euo pipefail

if ! sudo -u workshop --login command -v hindsight-api >/dev/null 2>&1; then
    workshopctl set-health error "hindsight-api is not installed; check the setup-project hook output"
    exit 0
fi

# Require an explicit model — none is defaulted. Fail loudly (error, not
# waiting) so the missing config is obvious and actionable.
MODEL="$(sed -n 's/^[[:space:]]*HINDSIGHT_API_LLM_MODEL[[:space:]]*=[[:space:]]*//p' /home/workshop/.hindsight/server.env 2>/dev/null | tail -1)"
if [ -z "$MODEL" ]; then
    workshopctl set-health error "HINDSIGHT_API_LLM_MODEL is not set in ~/.hindsight/server.env — set it to a model available on your LLM endpoint (e.g. qwen3.6:35b), then run: workshop refresh"
    exit 0
fi

# The API serves /health on :8888 once an LLM provider is configured. It has a
# cold start (embedded Postgres + model load takes ~20-30s), so poll for up to
# a minute before reporting "waiting" — Workshop then retries this hook, which
# covers the case where the user has not configured a provider key yet.
for _ in $(seq 1 20); do
    if curl -fsS -o /dev/null --max-time 3 http://127.0.0.1:8888/health 2>/dev/null; then
        echo -n "Hindsight API -> http://localhost:8888  |  Web UI -> http://localhost:9999"
        workshopctl set-health okay
        exit 0
    fi
    sleep 3
done

workshopctl set-health waiting "Hindsight API not responding on :8888 yet. If it does not come up, set an LLM provider in ~/.hindsight/server.env (HINDSIGHT_API_LLM_PROVIDER / HINDSIGHT_API_LLM_API_KEY) and run: workshop refresh"
